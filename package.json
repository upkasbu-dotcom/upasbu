{
  "name": "webapp",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && cp dist/index.js dist/_worker.js && mkdir -p dist/static && cp -r public/static/. dist/static/ && echo '{\"version\":1,\"include\":[\"/*\"],\"exclude\":[\"/static/*\"]}' > dist/_routes.json",
    "preview": "wrangler dev",
    "deploy": "npm run build && wrangler deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings"
  },
  "dependencies": {
    "@resvg/resvg-wasm": "^2.6.2",
    "exceljs": "^4.4.0",
    "hono": "^4.12.12",
    "satori": "^0.26.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@hono/vite-build": "^1.2.0",
    "@hono/vite-dev-server": "^0.18.2",
    "vite": "^6.3.5",
    "wrangler": "^4.4.0"
  }
}
