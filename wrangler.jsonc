{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "mesin-monitor",
  "pages_build_output_dir": "./dist",
  "compatibility_date": "2026-04-13",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "mesin-monitor-production",
      "database_id": "2af3a886-509c-4133-a390-351259e9474b"
    }
  ],
  "kv_namespaces": [
    {
      "binding": "FILES",
      "id": "b68842119a064bafa4813e70fe945dc6"
    }
  ]
}
